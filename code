    cout << "What genre of movie are you watching? (action, comedy, horror, romance, drama, sci-fi): ";
    cin >> genre;

    cout << "\nAnalyzing your vibe...\n\n";

    string recommendation;

    if (mood == "happy") {
        if (genre == "comedy")
            recommendation = "Caramel Popcorn";
        else if (genre == "action")
            recommendation = "Cheddar Popcorn";
        else
            recommendation = "Classic Butter Popcorn";
    }
    else if (mood == "sad") {
        if (genre == "romance" || genre == "drama")
            recommendation = "Chocolate Drizzle Popcorn";
        else
            recommendation = "Sweet & Salty Popcorn";
    }
    else if (mood == "adventurous") {
        if (genre == "sci-fi")
            recommendation = "Spicy Sriracha Popcorn";
        else if (genre == "horror")
            recommendation = "Ghost Pepper Popcorn";
        else
            recommendation = "BBQ Popcorn";
    }
    else if (mood == "romantic") {
        if (genre == "romance")
            recommendation = "Strawberry & White Chocolate Popcorn";
        else
            recommendation = "Caramel Popcorn";
    }
    else if (mood == "relaxed") {
        recommendation = "Classic Butter Popcorn";
    }
    else {
