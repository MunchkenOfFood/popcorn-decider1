        };
        return items[rand() % 4];
    }
    else if (roll <= 800) {
        rarity = "Rare 🔵";
        pityCounter++;
        string items[] = {
            "Cheddar Popcorn",
            "Loaded Cheese Nachos",
            "BBQ Popcorn",
            "Chili Nachos"
        };
        return items[rand() % 4];
    }
    else if (roll <= 900) {
        rarity = "Epic 🟣";
        pityCounter++;
        string items[] = {
            "Spicy Sriracha Popcorn",
            "Fiery Jalapeño Nachos",
            "Ghost Pepper Popcorn",
            "Sweet Heat Nachos"
        };
        return items[rand() % 4];
    }
    else if (roll <= 970) {
        rarity = "LEGENDARY 🟡🔥";
        pityCounter = 0;
        string items[] = {
            "Golden Caramel Deluxe Popcorn",
            "Volcano Supreme Nachos",
            "Diamond Truffle Popcorn",
            "Galaxy Inferno Nachos",
            "Royal Platinum Popcorn",
            "Molten Lava Nachos"
