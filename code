    }
}

// ================= MULTI PULL =================
void multiPull(int amount) {

    cout << "\n🎰🔥 ===== " << amount << " PULL START ===== 🔥🎰\n";

    bool gotEpicOrHigher = false;
    bool gotLegendaryOrHigher = false;

    for (int i = 1; i <= amount; i++) {
        string rarity;
        string item = getRandomItem(rarity);

        if (rarity.find("Epic") != string::npos ||
            rarity.find("LEGENDARY") != string::npos ||
            rarity.find("MYTHIC") != string::npos ||
            rarity.find("SPECIAL") != string::npos ||
            rarity.find("GODLY") != string::npos)
            gotEpicOrHigher = true;

        if (rarity.find("LEGENDARY") != string::npos ||
            rarity.find("MYTHIC") != string::npos ||
            rarity.find("SPECIAL") != string::npos ||
            rarity.find("GODLY") != string::npos)
            gotLegendaryOrHigher = true;

        cout << "\nPull #" << i << "\n";
        cout << "You pulled: " << item << "\n";
        cout << "Rarity: " << rarity << "\n";
    }

    if (amount >= 10 && !gotEpicOrHigher) {
        cout << "\n✨ BONUS GUARANTEED EPIC! ✨\n";
        cout << "You pulled: Ghost Pepper Popcorn\n";
        cout << "Rarity: Epic 🟣 (Guaranteed)\n";
        pityCounter++;
    }

    if (amount >= 20 && !gotLegendaryOrHigher) {
        cout << "\n👑 BONUS GUARANTEED LEGENDARY! 👑\n";
        cout << "You pulled: Golden Caramel Deluxe Popcorn\n";
        cout << "Rarity: LEGENDARY 🟡🔥 (Guaranteed)\n";
        pityCounter = 0;
    }

    cout << "\n🎰🔥 ===== PULL END ===== 🔥🎰\n\n";
}

