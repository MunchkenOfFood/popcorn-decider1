    }

    cout << "🎬 Your perfect popcorn flavor is: " 
         << recommendation << "!\n";

    // ===== GACHA MENU =====
    cout << "\nWould you like to do a Gacha pull?\n";
    cout << "1. Single Pull\n";
    cout << "2. 5 Pull\n";
    cout << "3. 10 Pull (Epic Guaranteed)\n";
    cout << "4. 20 Pull (Legendary Guaranteed)\n";
    cout << "5. No Thanks\n";
    cout << "Choice: ";
    cin >> gachaChoice;

    if (gachaChoice == 1)
        multiPull(1);
    else if (gachaChoice == 2)
        multiPull(5);
    else if (gachaChoice == 3)
        multiPull(10);
    else if (gachaChoice == 4)
        multiPull(20);
    else
        cout << "Maybe next time!\n";

    cout << "\nCurrent Pity Counter: "
         << pityCounter << " / " << PITY_LIMIT << "\n";

    cout << "\nEnjoy your movie night! 🍿✨\n";

    return 0;
}
